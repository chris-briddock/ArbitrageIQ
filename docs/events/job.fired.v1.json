{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.arbitrageiq.com/events/job.fired.v1.json",
  "title": "job.fired (v1)",
  "description": "Published by the Jobs Service when Hangfire dispatches a scheduled job. Consumed by all services for observability. See TDD Sections 3.2.1, 5.2.",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "schema_version",
    "timestamp",
    "source_service",
    "correlation_id",
    "payload"
  ],
  "additionalProperties": false,
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "const": "job.fired" },
    "schema_version": { "const": "1.0" },
    "timestamp": { "type": "string", "format": "date-time" },
    "source_service": { "const": "jobs-service" },
    "correlation_id": { "type": "string", "format": "uuid" },
    "payload": {
      "type": "object",
      "required": ["job_id", "job_type", "triggered_at", "retry_count"],
      "additionalProperties": false,
      "properties": {
        "job_id": { "type": "string", "description": "Hangfire job identifier." },
        "job_type": {
          "type": "string",
          "enum": ["price_ingestion", "nightly_scoring", "circuit_probing", "quarantine_replay", "retention_purge", "webhook_delivery"],
          "description": "The category of job being dispatched."
        },
        "triggered_at": { "type": "string", "format": "date-time", "description": "Scheduled time that triggered this job." },
        "retry_count": { "type": "integer", "minimum": 0, "description": "Number of previous attempts for this job. Zero on first run." }
      }
    }
  }
}
